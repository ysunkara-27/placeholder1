NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

ANTHROPIC_API_KEY=
APPLY_ENGINE_BASE_URL=http://127.0.0.1:8000
APPLY_ENGINE_TIMEOUT_MS=240000
APPLY_ENGINE_GREENHOUSE_TIMEOUT_MS=420000
APPLY_QUEUE_WORKER_SECRET=replace-with-a-long-random-secret

# ── Tracking layer (apply engine / Railway) ───────────────────────────────────
# Direct PostgreSQL connection for SQLAlchemy (Supabase → Settings → Database → URI)
# Use the "Transaction pooler" or "Direct connection" string, swap postgres:// → postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxx.supabase.co:5432/postgres

# Redis for Celery task queue + SSE pub/sub
# Use Upstash Redis or Railway Redis add-on
REDIS_URL=redis://localhost:6379/0

SMS_PROVIDER=plivo
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_PHONE_NUMBER=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
