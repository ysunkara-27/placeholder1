{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "apply_engine/Dockerfile",
    "watchPatterns": ["apply_engine/**"]
  },
  "deploy": {
    "startCommand": "python queue_worker.py",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
